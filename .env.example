# ==========================================
# FUMÊGO Pizza — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA suba o .env.local para o repositório.
# ==========================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL e chave anônima (públicas — usadas no cliente)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Chave de serviço (privada — usada apenas no servidor)
# Obtenha em: Supabase → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Autenticação ──────────────────────────────────────────────────────────────
# Segredo para assinar os JWTs dos usuários
# Gere com: openssl rand -hex 32
JWT_SECRET=seu-segredo-jwt-aqui

# ── Criptografia de CPF ───────────────────────────────────────────────────────
# Chave AES-256 para criptografar CPFs no banco de dados
# Gere com: openssl rand -hex 32
# ATENÇÃO: se perder esta chave, CPFs existentes não poderão ser descriptografados
CPF_ENCRYPTION_KEY=sua-chave-de-criptografia-aqui

# ── Admin ─────────────────────────────────────────────────────────────────────
# Segredo JWT exclusivo para sessões do painel admin (pode ser igual ao JWT_SECRET)
ADMIN_JWT_SECRET=seu-segredo-admin-jwt-aqui

# RECOMENDADO: hash bcrypt da senha do admin (gerado com bcryptjs, cost 12)
# Gere com: node -e "require('bcryptjs').hash('SUA_SENHA',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2b$12$...

# LEGADO: senha do admin em texto puro (substituir por ADMIN_PASSWORD_HASH acima)
# ADMIN_PASSWORD=sua-senha-admin

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Chave de acesso da conta Mercado Pago (começa com APP_USR-)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...

# Segredo para validar assinatura dos webhooks (configure no painel do MP)
# Configurar em: Mercado Pago → Suas integrações → Webhooks
MERCADO_PAGO_WEBHOOK_SECRET=seu-webhook-secret-aqui

# ── E-mail (Resend) ───────────────────────────────────────────────────────────
# Chave da API do Resend para envio de e-mails transacionais
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_...

# E-mail remetente (deve ser de um domínio verificado no Resend)
RESEND_FROM_EMAIL=noreply@seudominio.com.br

# ── URLs da Aplicação ─────────────────────────────────────────────────────────
# URL pública da aplicação (sem barra no final)
NEXT_PUBLIC_APP_URL=https://seudominio.com.br

# ── Open Delivery / CardápioWeb (opcional) ────────────────────────────────────
# URL base do CardápioWeb para push de eventos
# OD_CW_BASE_URL=https://merchant.cardapioweb.com

# Token de acesso para o CardápioWeb
# OD_CW_ACCESS_TOKEN=seu-token-cw

# Client ID e Secret para OAuth do Open Delivery
# OD_CLIENT_ID=seu-client-id
# OD_CLIENT_SECRET=seu-client-secret

# Merchant ID no Open Delivery
# OD_MERCHANT_ID=seu-merchant-id

# ── Monitoramento (opcional) ──────────────────────────────────────────────────
# DSN do Sentry para rastreamento de erros em produção
# Obtenha em: https://sentry.io → Settings → Projects → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=sua-org
# SENTRY_PROJECT=fumego-pizza
